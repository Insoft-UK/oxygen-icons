#!/bin/bash

DIR=$(dirname "$0")
clear

# Re-run script with sudo if not already root
if [ "$EUID" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

cd "$DIR"
set -e

# -------- CONFIG --------

# List of files and their new names
# Format: "source_path:new_name"
FILES=(
#    "32x32/actions/chronometer.png:start_32x32.png"
#    "16x16/actions/chronometer.png:start_16x16.png"
#    "64x64/actions/code-block.png:program_32x32.png"
#    "32x32/actions/code-block.png:program_16x16.png"
#    "64x64/actions/code-class.png:calc_tree_32x32.png"
#    "32x32/actions/code-class.png:calc_tree_16x16.png"
#    "64x64/actions/view-list-icons.png:apps_32x32.png"
#    "32x32/actions/view-list-icons.png:apps_16x16.png"
    "64x64/actions/document-new.png:add_new_32x32.png"
    "32x32/actions/document-new.png:add_new_16x16.png"
#    "64x64/actions/download.png:check_update_32x32.png"
#    "32x32/actions/download.png:check_update_16x16.png"
#    "64x64/actions/archive-insert-directory.png:new_folder_32x32.png"
#    "32x32/actions/archive-insert-directory.png:new_folder_16x16.png"
#    "64x64/actions/edit-paste.png:paste_32x32.png"
#    "32x32/actions/edit-paste.png:paste_16x16.png"
    "64x64/actions/document-open.png:open_32x32.png"
    "32x32/actions/document-open.png:open_16x16.png"
        
#    "64x64/apps/ark.png:backup_32x32.png"
#    "32x32/apps/ark.png:backup_16x16.png"
    
    "64x64/devices/video-television.png:monitor_32x32.png"
    "32x32/devices/video-television.png:monitor_16x16.png"
    
#    "64x64/places/folder-violet.png:cas_folder_32x32.png"
#    "32x32/places/folder-violet.png:cas_folder_16x16.png"
#    "64x64/places/folder-green.png:file_folder_32x32.png"
#    "32x32/places/folder-green.png:file_folder_16x16.png"
#    "64x64/places/folder-documents.png:content_32x32.png"
#    "32x32/places/folder-documents.png:content_16x16.png"
    
#    "64x64/status/dialog-information.png:about_32x32.png"
#    "32x32/status/dialog-information.png:about_16x16.png"
)

# Base Applications directory
APP_DIR="/Applications"

# -------- FIND TARGET APP --------

TARGET_APP=""

# Prefer ANY BETA version (version/build can vary)
TARGET_APP=$(find "$APP_DIR" -maxdepth 1 -type d -iname "HP Connectivity Kit*BETA*.app" | head -n 1)

# Fallback to non-BETA
if [ -z "$TARGET_APP" ]; then
    TARGET_APP=$(find "$APP_DIR" -maxdepth 1 -type d -iname "HP Connectivity Kit*.app" ! -iname "*BETA*" | head -n 1)
fi

# Final check
if [ -z "$TARGET_APP" ]; then
    echo "❌ No HP Connectivity Kit app found"
    exit 1
fi

echo "✅ Using: $TARGET_APP"

# -------- DESTINATION INSIDE APP --------

DEST="$TARGET_APP/Contents/Resources/icons"

if [ ! -d "$DEST" ]; then
    echo "❌ Destination folder not found: $DEST"
    exit 1
fi

# -------- COPY FILES --------
for entry in "${FILES[@]}"; do
    SRC="${entry%%:*}"
    NEW_NAME="${entry##*:}"

    if [ ! -f "$SRC" ]; then
        echo "⚠️ Skipping missing file: $SRC"
        continue
    fi

    echo "➡️ Copying $SRC → $DEST/$NEW_NAME"
    cp "$SRC" "$DEST/$NEW_NAME"
done

echo "🎉 Done"
